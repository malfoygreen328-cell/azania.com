{
  "routes": [
    {
      "route": "/signup",
      "rewrite": "/signup.html"
    },
    {
      "route": "/login",
      "rewrite": "/login.html"
    },
    {
      "route": "/products",
      "rewrite": "/products.html"
    },
    {
      "route": "/cart",
      "rewrite": "/cart.html"
    },

    // ✅ ADD THESE
    {
      "route": "/sitemap.xml",
      "serve": "/sitemap.xml"
    },
    {
      "route": "/sitemaps/*",
      "serve": "/sitemaps/:*"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/css/*",
      "/js/*",
      "/assets/*",
      "/sitemap.xml",
      "/sitemaps/*"
    ]
  }
}
